# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Real auth toggle — set to true once Supabase Auth is configured in your project dashboard
VITE_USE_REAL_AUTH=false

# Mock auth passwords (dev only — do not set in production)
VITE_MOCK_PASSWORD_OWNER=change_me_owner
VITE_MOCK_PASSWORD_ADMIN=change_me_admin
VITE_MOCK_PASSWORD_SARA=change_me_sara
VITE_MOCK_PASSWORD_ELENA=change_me_elena
VITE_MOCK_PASSWORD_DENIS=change_me_denis

# Telegram bot (optional)
VITE_TELEGRAM_BOT_USERNAME=iconoff_bot

# Edge Functions
FRONTEND_URL=http://localhost:8080
